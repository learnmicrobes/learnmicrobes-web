{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "ui_kits/social/**",
              "ui_kits/web_app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|shape|size|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, shape, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:sage|teal|soft|gold|error|onDark)$/]",
        "message": "<Badge> variant must be one of 'sage' | 'teal' | 'soft' | 'gold' | 'error' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:rounded|circle)$/]",
        "message": "<Badge> shape must be one of 'rounded' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BenchFinding'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|accent|key|ref|className|style|children)$/]",
        "message": "<BenchFinding> doesn't accept that prop. Declared props: label, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|pill|block|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, pill, block, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|secondary|ghost|ghost-dark|onDark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'secondary' | 'ghost' | 'ghost-dark' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|children|tone|onDark|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: eyebrow, children, tone, onDark."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|info|success|caution|gold)$/]",
        "message": "<Callout> tone must be one of 'neutral' | 'info' | 'success' | 'caution' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:interactive|pad|radius|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: interactive, pad, radius."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='pad'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> pad must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Card> radius must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|label|variant|size|disabled|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, label, variant, size, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid|ghost|onDark)$/]",
        "message": "<IconButton> variant must be one of 'soft' | 'solid' | 'ghost' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|icon|invalid|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, icon, invalid."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|as|key|ref|className|style|children)$/]",
        "message": "<Kicker> doesn't accept that prop. Declared props: tone, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|size|dot|uppercase|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: children, tone, size, dot, uppercase."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|teal|sage|soft|outline|gold|onDark)$/]",
        "message": "<Pill> tone must be one of 'dark' | 'teal' | 'sage' | 'soft' | 'outline' | 'gold' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Pill> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressDots'] > JSXAttribute > JSXIdentifier[name!=/^(?:total|current|variant|onDark|key|ref|className|style|children)$/]",
        "message": "<ProgressDots> doesn't accept that prop. Declared props: total, current, variant, onDark."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressDots'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:dots|counter)$/]",
        "message": "<ProgressDots> variant must be one of 'dots' | 'counter'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuizOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:letter|state|key|ref|className|style|children)$/]",
        "message": "<QuizOption> doesn't accept that prop. Declared props: letter, state."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchField'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|label|glass|key|ref|className|style|children)$/]",
        "message": "<SearchField> doesn't accept that prop. Declared props: value, onChange, placeholder, label, glass."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpecimenFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|label|ratio|key|ref|className|style|children)$/]",
        "message": "<SpecimenFrame> doesn't accept that prop. Declared props: src, alt, label, ratio."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|onDark|key|ref|className|style|children)$/]",
        "message": "<StatChip> doesn't accept that prop. Declared props: value, label, icon, onDark."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:accent|onDark|dot|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: accent, onDark, dot."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
